{
  "id": "voyager",
  "name": "Voyager",
  "description": "Long-horizon research agent for deep exploration, technology audits, and knowledge synthesis.",
  "system": "You are a senior research and execution agent. Produce concise, source-backed work, prefer event-driven designs, and capture reusable findings as memory notes.",
  "model": "gpt-5.4",
  "runtime": "rust-core",
  "deployment": {
    "controlPlane": "local",
    "execution": "local-runner",
    "workflow": "research"
  },
  "tags": ["research", "analysis", "planning", "knowledge"],
  "prompts": {
    "system": "system/core.md",
    "personality": "agents/voyager.md",
    "stages": {
      "gather": "system/autonomy.md",
      "summarize": "system/user-experience.md",
      "learn": "workflows/autonomous-loop.md"
    }
  },
  "contextTriggers": [
    {
      "id": "voyager-research-context",
      "event": "goal_received",
      "conditions": [
        { "type": "goal_contains", "value": ["research", "audit", "analyze", "investigate", "compare", "review", "scan", "explore"] }
      ],
      "actions": [
        { "type": "inject_prompt", "target": "agents/voyager.md" },
        { "type": "query_memory", "target": "research", "maxChunks": 8 },
        { "type": "inject_trajectory", "lastNSteps": 3 }
      ],
      "priority": 90
    },
    {
      "id": "voyager-gather-memory",
      "event": "step_started",
      "conditions": [
        { "type": "stage_is", "value": "gather" }
      ],
      "actions": [
        { "type": "query_memory", "target": "research", "maxChunks": 6 }
      ],
      "priority": 80
    },
    {
      "id": "voyager-slack-format",
      "event": "channel_message",
      "conditions": [
        { "type": "channel_is", "value": "slack" }
      ],
      "actions": [
        { "type": "inject_channel_format", "target": "slack" },
        { "type": "inject_prompt", "target": "social/channels.md" }
      ],
      "priority": 70
    },
    {
      "id": "voyager-github-format",
      "event": "channel_message",
      "conditions": [
        { "type": "channel_is", "value": "github" }
      ],
      "actions": [
        { "type": "inject_channel_format", "target": "github" },
        { "type": "inject_prompt", "target": "social/channels.md" }
      ],
      "priority": 70
    },
    {
      "id": "voyager-step-trajectory",
      "event": "step_completed",
      "conditions": [],
      "actions": [
        { "type": "log_trajectory" }
      ],
      "priority": 50
    },
    {
      "id": "voyager-dream-consolidation",
      "event": "run_completed",
      "conditions": [
        { "type": "step_count_at_least", "value": 5 }
      ],
      "actions": [
        { "type": "consolidate_memory" }
      ],
      "priority": 40
    }
  ],
  "tools": {
    "allowExec": true,
    "allowBrowser": true,
    "allowNetwork": true,
    "allowMcp": true,
    "browser": {
      "enabled": true,
      "allowedDomains": ["github.com", "vercel.com", "docs.anthropic.com", "openai.com"],
      "blockedDomains": [],
      "maxConcurrentSessions": 2,
      "allowDownloads": false,
      "defaultMode": "extract",
      "requiresApprovalFor": ["form", "download"]
    }
  },
  "memory": {
    "namespace": "research",
    "maxNotes": 400,
    "summarizeAfter": 32
  },
  "workflowTemplates": [
    {
      "id": "research-default",
      "description": "Research with browser-backed gathering and durable learning.",
      "stages": ["route", "plan", "gather", "act", "verify", "summarize", "learn"]
    }
  ],
  "toolProfiles": [
    {
      "id": "research-browser",
      "description": "Read-only browsing for research, docs, and verification."
    }
  ],
  "handoffRules": [
    {
      "id": "research-browser-handoff",
      "whenGoalIncludes": ["browser", "research", "docs", "audit", "verify"],
      "to": "browser-worker",
      "reason": "Browser evidence should flow through durable browser tasks."
    }
  ],
  "learningPolicy": {
    "enabled": true,
    "summarizeEveryRuns": 3,
    "embedMemory": true,
    "maxRetrievedChunks": 8
  },
  "schedules": [
    {
      "id": "market-scan",
      "goal": "Compile a fresh research scan for the validator rollout and summarize the highest-signal changes.",
      "intervalMinutes": 15,
      "priority": "normal",
      "enabled": true,
      "requestedBy": "scheduler-local"
    }
  ]
}
