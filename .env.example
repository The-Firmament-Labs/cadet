# ============================================================
# Cadet (Starbridge) Environment Variables
# ============================================================
# Copy to .env.local and fill in values.
# On Vercel, set these via `vercel env` or the dashboard.

# --- SpacetimeDB (Required) ---
# Connection URL for the SpacetimeDB instance.
# Local: http://127.0.0.1:3000 | Cloud: your SpacetimeDB cloud URL
SPACETIMEDB_URL=http://127.0.0.1:3000

# Database name within SpacetimeDB
SPACETIMEDB_DATABASE=starbridge-control

# Auth token for SpacetimeDB API calls (required for cloud deployments)
SPACETIMEDB_AUTH_TOKEN=

# --- Local Control Plane (Optional — only for apps/local-control) ---
PORT=3010
STARBRIDGE_MANIFEST_DIR=./examples/agents
STARBRIDGE_RUNNER_BIN=
STARBRIDGE_HEARTBEAT_INTERVAL_MS=30000
STARBRIDGE_SCHEDULE_INTERVAL_MS=30000
STARBRIDGE_PRESENCE_TTL_MS=90000

# --- Cloud Control Plane / Vercel (Required for apps/web) ---
# Public URL of the web control plane.
# On Vercel this is auto-derived from VERCEL_PROJECT_PRODUCTION_URL if unset.
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:3001

# Secret used to authenticate Vercel Cron Job requests.
# Must match the value configured in Vercel project env vars.
# Vercel sends this as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-me

# --- Operator Authentication (Optional) ---
# Secret for NextAuth session signing.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of emails allowed to sign in as operators.
OPERATOR_AUTH_ALLOWED_EMAILS=

# --- SpacetimeAuth OIDC (Preferred auth provider) ---
SPACETIMEAUTH_ISSUER=https://auth.spacetimedb.com/oidc
SPACETIMEAUTH_CLIENT_ID=
SPACETIMEAUTH_CLIENT_SECRET=

# --- Auth0 OIDC (Alternative auth provider) ---
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- Sign in with Vercel (Optional — enables Vercel OAuth for end-users) ---
# Register at https://vercel.com/dashboard/{team}/integrations/console
# Set redirect URI to: https://<your-domain>/api/auth/vercel/callback
VERCEL_INTEGRATION_CLIENT_ID=
VERCEL_INTEGRATION_CLIENT_SECRET=
# Set to "true" to show "Sign in with Vercel" button on the sign-in page
NEXT_PUBLIC_VERCEL_OAUTH_ENABLED=

# --- Webhook Signature Verification (Required for production) ---
# Slack: found in your Slack App's "Signing Secret" setting
# SLACK_SIGNING_SECRET=
# GitHub: set when creating the webhook in repo settings
# GITHUB_WEBHOOK_SECRET=

# --- Discord Bot (Optional — enables Discord integration) ---
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=

# --- Vercel Sandbox (Optional — enables coding agent sandboxes) ---
# Default sandbox snapshot template ID (speeds up cold starts)
# SANDBOX_DEFAULT_TEMPLATE=
# Idle timeout before auto-sleep (ms, default 300000 = 5 min)
# SANDBOX_IDLE_TIMEOUT_MS=300000
# Max sandboxes per operator (default 5)
# SANDBOX_MAX_PER_OPERATOR=5

# --- Vercel Queues (Optional — enables async job dispatch) ---
# Set to "true" to use queue-based dispatch instead of synchronous
# VERCEL_QUEUES_ENABLED=

# --- Vercel Workflow DevKit (Optional — enables durable agent workflows) ---
# Set to "true" to wrap agent execution in crash-proof durable workflows
# WORKFLOW_ENABLED=
