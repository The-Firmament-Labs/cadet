# Shared SpacetimeDB settings
SPACETIMEDB_URL=http://127.0.0.1:3000
SPACETIMEDB_DATABASE=starbridge-control
SPACETIMEDB_AUTH_TOKEN=

# Local control plane
PORT=3010
STARBRIDGE_MANIFEST_DIR=./examples/agents
STARBRIDGE_RUNNER_BIN=
STARBRIDGE_HEARTBEAT_INTERVAL_MS=30000
STARBRIDGE_SCHEDULE_INTERVAL_MS=30000
STARBRIDGE_PRESENCE_TTL_MS=90000

# Cloud control plane / Vercel
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:3001
CRON_SECRET=replace-me

# Operator authentication (optional)
AUTH_SECRET=
OPERATOR_AUTH_ALLOWED_EMAILS=

# SpacetimeAuth (preferred for the operator UI)
SPACETIMEAUTH_ISSUER=https://auth.spacetimedb.com/oidc
SPACETIMEAUTH_CLIENT_ID=
SPACETIMEAUTH_CLIENT_SECRET=

# Auth0 (alternative OIDC provider)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
